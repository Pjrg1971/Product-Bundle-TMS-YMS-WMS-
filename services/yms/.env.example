# ============================================================
# YardCommand Pro — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Supabase ---
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJh...           # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJh...   # "service_role" key — keep secret, server only
SUPABASE_JWT_SECRET=your-jwt-secret # Settings → API → JWT Secret

# --- Stripe ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...       # use sk_test_... during development
STRIPE_WEBHOOK_SECRET=whsec_...     # from Stripe Dashboard → Webhooks

# Stripe Price IDs — create products in Stripe Dashboard first
STRIPE_PRICE_STARTER=price_...      # $499/mo Starter plan
STRIPE_PRICE_PRO=price_...          # $1,299/mo Pro plan
STRIPE_PRICE_ENTERPRISE=price_...   # Enterprise (custom)

# Stripe Add-on Price IDs
STRIPE_PRICE_ADDON_API=price_...        # $199/mo API Access
STRIPE_PRICE_ADDON_AI=price_...         # $399/mo AI Optimization
STRIPE_PRICE_ADDON_ANALYTICS=price_...  # $149/mo Advanced Analytics
STRIPE_PRICE_ADDON_AUTONOMOUS=price_... # $599/mo Autonomous Jockey

# --- Server ---
PORT=4000
CLIENT_ORIGIN=https://your-frontend-domain.com   # or http://localhost:3000 for dev

# --- Environment ---
NODE_ENV=development   # change to "production" when deployed
