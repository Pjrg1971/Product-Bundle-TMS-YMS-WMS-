# ============================================================
# Cowork Logistics Platform — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cowork_logistics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cowork_logistics

# ── API Gateway ─────────────────────────────────────────────
GATEWAY_PORT=3000
TMS_URL=http://localhost:4100
WMS_URL=http://localhost:8000
YMS_URL=http://localhost:4000

# ── TMS (Transportation Management System) ──────────────────
TMS_PORT=4100

# ── WMS (Warehouse Management System) ───────────────────────
WMS_PORT=8000
WMS_DB_SCHEMA=wms

# ── YMS (Yard Management System) ────────────────────────────
YMS_PORT=4000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── Stripe (YMS Billing) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# ── CORS ─────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
